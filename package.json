{
  "name": "yars-dpsk-copilot",
  "displayName": "Yar's deepseek copilot",
  "description": "A VS Code copilot specialized on DeepSeek.",
  "version": "0.1.0",
  "preview": true,
  "publisher": "yarcrasy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YarCrasy/deepseek-copilot.git"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "deepseek-copilot.openChat",
        "title": "DeepSeek Copilot: Open Chat",
        "category": "DeepSeek Copilot"
      },
      {
        "command": "deepseek-copilot.addFileToChat",
        "title": "DeepSeek Copilot: Add File to Chat",
        "category": "DeepSeek Copilot",
        "icon": "$(add)"
      },
      {
        "command": "deepseek-copilot.addFolderToChat",
        "title": "DeepSeek Copilot: Add Folder to Chat",
        "category": "DeepSeek Copilot",
        "icon": "$(add)"
      },
      {
        "command": "deepseek-copilot.addSelectionToChat",
        "title": "DeepSeek Copilot: Add Selection to Chat",
        "category": "DeepSeek Copilot",
        "icon": "$(add)"
      },
      {
        "command": "deepseek-copilot.newChat",
        "title": "DeepSeek Copilot: New Chat",
        "category": "DeepSeek Copilot",
        "icon": "$(add)"
      },
      {
        "command": "deepseek-copilot.reviewChanges",
        "title": "DeepSeek Copilot: Review Changes",
        "category": "DeepSeek Copilot",
        "icon": "$(git-pull-request)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "deepseek-copilot.addFileToChat",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "navigation@50"
        },
        {
          "command": "deepseek-copilot.addFolderToChat",
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "group": "navigation@51"
        }
      ],
      "editor/context": [
        {
          "command": "deepseek-copilot.addSelectionToChat",
          "when": "editorHasSelection",
          "group": "navigation@50"
        },
        {
          "command": "deepseek-copilot.reviewChanges",
          "when": "resourceScheme == file",
          "group": "navigation@51"
        }
      ],
      "view/title": [
        {
          "command": "deepseek-copilot.newChat",
          "when": "view == deepseek-copilot.chatView",
          "group": "navigation@1"
        }
      ],
      "scm/title": [
        {
          "command": "deepseek-copilot.reviewChanges",
          "group": "navigation@50"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "deepseek-copilot-sidebar",
          "title": "DeepSeek Copilot",
          "icon": "src/assets/DeepSeekIcon.svg"
        }
      ]
    },
    "views": {
      "deepseek-copilot-sidebar": [
        {
          "type": "webview",
          "id": "deepseek-copilot.chatView",
          "name": "Chat",
          "icon": "src/assets/DeepSeekIcon.svg",
          "visibility": "visible"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "DeepSeek Copilot",
      "properties": {
        "deepseek-copilot.model": {
          "type": "string",
          "default": "deepseek-v4-flash",
          "scope": "application",
          "description": "DeepSeek model ID to use"
        },
        "deepseek-copilot.thinkingMode": {
          "type": "boolean",
          "default": true,
          "scope": "application",
          "description": "Enable DeepSeek thinking mode for reasoning models"
        },
        "deepseek-copilot.reasoningEffort": {
          "type": "string",
          "default": "high",
          "scope": "application",
          "enum": [
            "high",
            "max"
          ],
          "description": "DeepSeek reasoning effort level"
        },
        "deepseek-copilot.temperature": {
          "type": "number",
          "default": 1,
          "scope": "application",
          "description": "Sampling temperature"
        },
        "deepseek-copilot.topP": {
          "type": "number",
          "default": 1,
          "scope": "application",
          "description": "Top P sampling"
        },
        "deepseek-copilot.maxTokens": {
          "type": "number",
          "default": 8192,
          "scope": "application",
          "description": "Maximum tokens for responses"
        },
        "deepseek-copilot.responseFormat": {
          "type": "string",
          "default": "text",
          "scope": "application",
          "enum": [
            "text",
            "json_object"
          ],
          "description": "Response format"
        },
        "deepseek-copilot.streamResponse": {
          "type": "boolean",
          "default": true,
          "scope": "application",
          "description": "Enable streaming responses"
        },
        "deepseek-copilot.permissionMode": {
          "type": "string",
          "default": "read-only",
          "scope": "application",
          "enum": [
            "chat",
            "read-only",
            "workspace",
            "full-access"
          ],
          "enumDescriptions": [
            "Chat only; no tools are available.",
            "Allow read-only workspace tools.",
            "Allow read-only tools plus workspace file creation, edits, and patches.",
            "Allow all tools. Dangerous commands still require confirmation."
          ],
          "description": "Global permission mode for tool access"
        },
        "deepseek-copilot.autoContext": {
          "type": "boolean",
          "default": false,
          "scope": "application",
          "description": "Automatically include the active editor and git status/diff context with chat requests."
        },
        "deepseek-copilot.projectInstructions.includeHomeAgents": {
          "type": "boolean",
          "default": false,
          "scope": "application",
          "description": "Allow DeepSeek Copilot to read ~/.deepseek-copilot/AGENTS.md as a global instruction source."
        },
        "deepseek-copilot.toolExecutionModes": {
          "type": "object",
          "default": {},
          "scope": "application",
          "patternProperties": {
            "^[a-zA-Z0-9_-]+$": {
              "type": "string",
              "enum": [
                "disabled",
                "enabled",
                "auto_approve"
              ]
            }
          },
          "additionalProperties": false,
          "description": "Per-tool execution modes"
        },
        "deepseek-copilot.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "scope": "application",
          "description": "DeepSeek API base URL"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./ --noEmit",
    "watch": "tsc -watch -p ./ --noEmit",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "node esbuild.js --production",
    "build:webview": "vite build --config src/ui/vite.config.ts",
    "dev:webview": "vite --config src/ui/vite.config.ts --host 0.0.0.0 --port 5175 --strictPort",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "npm run test:unit && vscode-test",
    "test:unit": "node scripts/run-unit-tests.mjs"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "refractor": "^5.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "26.x",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.125.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "mocha": "^11.7.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
