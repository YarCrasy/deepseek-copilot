{
  "name": "yrs-dpsk-copilot",
  "displayName": "Yar's Deepseek copilot - A VS Code copilot specialized on Deepseek.",
  "description": "A deeply integrated VS Code coding assistant specialized in DeepSeek.",
  "version": "0.1.1",
  "preview": true,
  "publisher": "yarcrasy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YarCrasy/deepseek-copilot.git"
  },
  "homepage": "https://yarcrasy.github.io/deepseek-copilot/",
  "bugs": {
    "url": "https://github.com/YarCrasy/deepseek-copilot/issues"
  },
  "icon": "src/assets/DeepSeekIcon.png",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "deepseek",
    "ai",
    "assistant",
    "copilot",
    "chat",
    "coding",
    "agent"
  ],
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "yrs-dpsk-copilot.openChat",
        "title": "Yar's DeepSeek Copilot: Open Chat",
        "category": "Yar's DeepSeek Copilot"
      },
      {
        "command": "yrs-dpsk-copilot.addFileToChat",
        "title": "Yar's DeepSeek Copilot: Add File to Chat",
        "category": "Yar's DeepSeek Copilot",
        "icon": "$(add)"
      },
      {
        "command": "yrs-dpsk-copilot.addFolderToChat",
        "title": "Yar's DeepSeek Copilot: Add Folder to Chat",
        "category": "Yar's DeepSeek Copilot",
        "icon": "$(add)"
      },
      {
        "command": "yrs-dpsk-copilot.addSelectionToChat",
        "title": "Yar's DeepSeek Copilot: Add Selection to Chat",
        "category": "Yar's DeepSeek Copilot",
        "icon": "$(add)"
      },
      {
        "command": "yrs-dpsk-copilot.newChat",
        "title": "Yar's DeepSeek Copilot: New Chat",
        "category": "Yar's DeepSeek Copilot",
        "icon": "$(add)"
      },
      {
        "command": "yrs-dpsk-copilot.reviewChanges",
        "title": "Yar's DeepSeek Copilot: Review Changes",
        "category": "Yar's DeepSeek Copilot",
        "icon": "$(git-pull-request)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "yrs-dpsk-copilot.addFileToChat",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "navigation@50"
        },
        {
          "command": "yrs-dpsk-copilot.addFolderToChat",
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "group": "navigation@51"
        }
      ],
      "editor/context": [
        {
          "command": "yrs-dpsk-copilot.addSelectionToChat",
          "when": "editorHasSelection",
          "group": "navigation@50"
        },
        {
          "command": "yrs-dpsk-copilot.reviewChanges",
          "when": "resourceScheme == file",
          "group": "navigation@51"
        }
      ],
      "scm/title": [
        {
          "command": "yrs-dpsk-copilot.reviewChanges",
          "group": "navigation@50"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "yrs-dpsk-copilot-sidebar",
          "title": "Yar's DeepSeek Copilot",
          "icon": "src/assets/DeepSeekIcon.svg"
        }
      ]
    },
    "views": {
      "yrs-dpsk-copilot-sidebar": [
        {
          "type": "webview",
          "id": "yrs-dpsk-copilot.chatView",
          "name": "Chat",
          "icon": "src/assets/DeepSeekIcon.svg",
          "visibility": "visible"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Yar's DeepSeek Copilot",
      "properties": {
        "yrs-dpsk-copilot.model": {
          "type": "string",
          "default": "deepseek-v4-flash",
          "scope": "application",
          "description": "DeepSeek model ID to use"
        },
        "yrs-dpsk-copilot.thinkingMode": {
          "type": "boolean",
          "default": true,
          "scope": "application",
          "description": "Enable DeepSeek thinking mode for reasoning models"
        },
        "yrs-dpsk-copilot.reasoningEffort": {
          "type": "string",
          "default": "high",
          "scope": "application",
          "enum": [
            "high",
            "max"
          ],
          "description": "DeepSeek reasoning effort level"
        },
        "yrs-dpsk-copilot.temperature": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 2,
          "scope": "application",
          "description": "Sampling temperature"
        },
        "yrs-dpsk-copilot.topP": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 1,
          "scope": "application",
          "description": "Top P sampling"
        },
        "yrs-dpsk-copilot.maxTokens": {
          "type": "number",
          "default": 8192,
          "minimum": 1,
          "maximum": 65536,
          "scope": "application",
          "description": "Maximum tokens for responses"
        },
        "yrs-dpsk-copilot.maxToolRounds": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 20,
          "scope": "application",
          "description": "Maximum tool-call rounds per turn"
        },
        "yrs-dpsk-copilot.responseFormat": {
          "type": "string",
          "default": "text",
          "scope": "application",
          "enum": [
            "text",
            "json_object"
          ],
          "description": "Response format"
        },
        "yrs-dpsk-copilot.permissionMode": {
          "type": "string",
          "default": "read-only",
          "scope": "application",
          "enum": [
            "chat",
            "read-only",
            "workspace",
            "full-access"
          ],
          "enumDescriptions": [
            "Chat only; no tools are available.",
            "Allow read-only workspace tools.",
            "Allow read-only tools plus workspace file creation, edits, and patches.",
            "Allow all tools. Dangerous commands still require confirmation."
          ],
          "description": "Global permission mode for tool access"
        },
        "yrs-dpsk-copilot.enableBetaFeatures": {
          "type": "boolean",
          "default": false,
          "scope": "application",
          "description": "Enable DeepSeek beta features, including strict tool-call schemas."
        },
        "yrs-dpsk-copilot.autoContext": {
          "type": "boolean",
          "default": false,
          "scope": "application",
          "description": "Automatically include the active editor and git status/diff context with chat requests."
        },
        "yrs-dpsk-copilot.historyEnabled": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "description": "Store chat history for this workspace."
        },
        "yrs-dpsk-copilot.historyRetentionDays": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "maximum": 3650,
          "scope": "window",
          "description": "History retention in days. Use 0 to keep history until manually deleted."
        },
        "yrs-dpsk-copilot.projectInstructions.includeHomeAgents": {
          "type": "boolean",
          "default": false,
          "scope": "application",
          "description": "Allow Yar's DeepSeek Copilot to read ~/.yrs-dpsk-copilot/AGENTS.md as a global instruction source."
        },
        "yrs-dpsk-copilot.toolExecutionModes": {
          "type": "object",
          "default": {},
          "scope": "application",
          "patternProperties": {
            "^[a-zA-Z0-9_-]+$": {
              "type": "string",
              "enum": [
                "disabled",
                "enabled",
                "auto_approve"
              ]
            }
          },
          "additionalProperties": false,
          "description": "Per-tool execution modes"
        },
        "yrs-dpsk-copilot.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "scope": "application",
          "description": "DeepSeek API base URL"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./ --noEmit",
    "watch": "tsc -watch -p ./ --noEmit",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "node esbuild.js --production",
    "build:webview": "vite build --config src/ui/vite.config.ts",
    "dev:webview": "vite --config src/ui/vite.config.ts --host 0.0.0.0 --port 5175 --strictPort",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node scripts/run-unit-tests.mjs",
    "test:integration": "npm run build && esbuild src/test/Extension.test.ts --bundle --platform=node --format=cjs --external:vscode --outfile=out/test/Extension.test.js && vscode-test"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "refractor": "^5.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "26.x",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.125.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "mocha": "^11.7.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  },
  "overrides": {
    "diff": "9.0.0",
    "serialize-javascript": "7.0.7"
  }
}
