{
  "name": "yrs-dpsk-copilot",
  "displayName": "Yar's Deepseek copilot - A VS Code copilot specialized on Deepseek.",
  "description": "A deeply integrated VS Code coding assistant specialized in DeepSeek.",
  "version": "0.1.2",
  "preview": true,
  "publisher": "yarcrasy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YarCrasy/deepseek-copilot.git"
  },
  "homepage": "https://yarcrasy.github.io/deepseek-copilot/",
  "bugs": {
    "url": "https://github.com/YarCrasy/deepseek-copilot/issues"
  },
  "icon": "src/assets/DeepSeekIcon.png",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "deepseek",
    "ai",
    "assistant",
    "copilot",
    "chat",
    "coding",
    "agent"
  ],
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "yrs-dpsk-copilot.openChat",
        "title": "Yar's DeepSeek Copilot: Open Chat",
        "category": "Yar's DeepSeek Copilot"
      },
      {
        "command": "yrs-dpsk-copilot.addFileToChat",
        "title": "Yar's DeepSeek Copilot: Add File to Chat",
        "category": "Yar's DeepSeek Copilot",
        "icon": "$(add)"
      },
      {
        "command": "yrs-dpsk-copilot.addSelectionToChat",
        "title": "Yar's DeepSeek Copilot: Add Selection to Chat",
        "category": "Yar's DeepSeek Copilot",
        "icon": "$(add)"
      },
      {
        "command": "yrs-dpsk-copilot.newChat",
        "title": "Yar's DeepSeek Copilot: New Chat",
        "category": "Yar's DeepSeek Copilot",
        "icon": "$(add)"
      },
      {
        "command": "yrs-dpsk-copilot.reviewChanges",
        "title": "Yar's DeepSeek Copilot: Review Changes",
        "category": "Yar's DeepSeek Copilot",
        "icon": "$(git-pull-request)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "yrs-dpsk-copilot.addFileToChat",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "navigation@50"
        }
      ],
      "editor/context": [
        {
          "command": "yrs-dpsk-copilot.addSelectionToChat",
          "when": "editorHasSelection",
          "group": "navigation@50"
        },
        {
          "command": "yrs-dpsk-copilot.reviewChanges",
          "when": "resourceScheme == file",
          "group": "navigation@51"
        }
      ],
      "scm/title": [
        {
          "command": "yrs-dpsk-copilot.reviewChanges",
          "group": "navigation@50"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "yrs-dpsk-copilot-sidebar",
          "title": "Yar's DeepSeek Copilot",
          "icon": "src/assets/DeepSeekIcon.svg"
        }
      ]
    },
    "views": {
      "yrs-dpsk-copilot-sidebar": [
        {
          "type": "webview",
          "id": "yrs-dpsk-copilot.chatView",
          "name": "Chat",
          "icon": "src/assets/DeepSeekIcon.svg",
          "visibility": "visible"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./ --noEmit",
    "watch": "tsc -watch -p ./ --noEmit",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "node esbuild.js --production",
    "build:webview": "vite build --config src/ui/vite.config.ts",
    "dev:webview": "vite --config src/ui/vite.config.ts --host 0.0.0.0 --port 5175 --strictPort",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node scripts/run-unit-tests.mjs",
    "test:integration": "npm run build && node ./node_modules/esbuild/bin/esbuild src/test/Extension.test.ts --bundle --platform=node --format=cjs --external:vscode --outfile=out/test/Extension.test.js && vscode-test"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "refractor": "^5.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "26.x",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.125.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "mocha": "^11.7.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "@vscode/vsce-sign@2.0.9": true,
    "keytar@7.9.0": true
  },
  "overrides": {
    "diff": "9.0.0",
    "serialize-javascript": "7.0.7"
  }
}
