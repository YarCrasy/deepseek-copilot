---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { anchorId, languages, pageContent, pageSlugs, type Language, type PageSlug } from "../../i18n";

export function getStaticPaths() {
  return languages.flatMap((lang) => pageSlugs.map((slug) => ({ params: { lang, slug } })));
}

const lang = Astro.params.lang;
const slug = Astro.params.slug;
const pageLang = lang as Language;
const pageSlug = slug as PageSlug;
const content = pageContent[pageLang][pageSlug];
---
<DocsLayout title={content.title} description={content.description} lang={pageLang} currentSlug={pageSlug}>
  <h1>{content.title}</h1>
  <p class="lead">{content.lead}</p>
  {content.sections.map((section) => (
    <section>
      <h2 id={anchorId(section.title)}>{section.title}</h2>
      <ul>
        {section.items.map((item) => <li>{item}</li>)}
      </ul>
    </section>
  ))}
</DocsLayout>
