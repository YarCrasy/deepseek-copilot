---
import DocsLayout from "../layouts/DocsLayout.astro";
import { homeContent, navLabels, pageSlugs } from "../i18n";

const lang = "en";
const content = homeContent[lang];
---
<DocsLayout title={content.title} description={content.description} lang={lang}>
  <h1>DeepSeek Copilot</h1>
  <p class="lead">{content.lead}</p>
  <table class="metadataTable" aria-label="Project metadata">
    <tbody>
      <tr>
        <th scope="row">Provider</th>
        <td>DeepSeek only</td>
      </tr>
      <tr>
        <th scope="row">VS Code surface</th>
        <td>Sidebar chat, settings, history, workspace tools, and path autocomplete.</td>
      </tr>
      <tr>
        <th scope="row">Status</th>
        <td>Marketplace beta preparation.</td>
      </tr>
    </tbody>
  </table>
  <p>
    Available languages:
    <a href="en/">English</a>,
    <a href="es/">Español</a>,
    <a href="zh/">中文</a>.
  </p>
  <section class="sectionList" aria-label="Sections">
    {pageSlugs.map((slug) => (
      <a href={`${lang}/${slug}/`}>
        <strong>{navLabels[lang][slug]}</strong>
        <span>{content.cards[slug]}</span>
      </a>
    ))}
  </section>
</DocsLayout>
