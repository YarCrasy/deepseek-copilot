---
import DocsLayout from "../layouts/DocsLayout.astro";
import { anchorId, pageContent } from "../i18n";

const lang = "en";
const content = pageContent[lang]["technical-decisions"];
---
<DocsLayout title={content.title} description={content.description} lang={lang} currentSlug="technical-decisions">
  <h1>{content.title}</h1>
  <p class="lead">{content.lead}</p>
  {content.sections.map((section) => (
    <section>
      <h2 id={anchorId(section.title)}>{section.title}</h2>
      <ul>{section.items.map((item) => <li>{item}</li>)}</ul>
    </section>
  ))}
</DocsLayout>
