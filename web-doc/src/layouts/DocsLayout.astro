---
const { title, description } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | DeepSeek Copilot</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <header class="siteHeader">
      <a class="brand" href="/">DeepSeek Copilot</a>
      <nav aria-label="Documentacion">
        <a href="/intro/">Intro</a>
        <a href="/changelog/">Changelog</a>
        <a href="/references/">Referencias</a>
        <a href="/technical-decisions/">Decisiones</a>
        <a href="/user-manual/">Manual</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f7f7f4;
    color: #202124;
  }

  body {
    margin: 0;
  }

  a {
    color: inherit;
  }

  .siteHeader {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 18px clamp(20px, 5vw, 72px);
    border-bottom: 1px solid #d8d8d2;
    background: #fffefa;
  }

  .brand {
    font-weight: 700;
    text-decoration: none;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    font-size: 0.95rem;
  }

  nav a {
    text-decoration: none;
  }

  main {
    width: min(980px, calc(100% - 40px));
    margin: 0 auto;
    padding: 48px 0 72px;
  }

  h1 {
    font-size: clamp(2.25rem, 7vw, 4.75rem);
    line-height: 0.98;
    margin: 0 0 20px;
    letter-spacing: 0;
  }

  h2 {
    margin-top: 42px;
  }

  p,
  li {
    line-height: 1.7;
  }

  .lead {
    max-width: 760px;
    font-size: 1.2rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 18px;
    margin-top: 32px;
  }

  .card {
    border: 1px solid #d8d8d2;
    border-radius: 8px;
    padding: 20px;
    background: #fffefa;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      background: #171816;
      color: #f1f0ea;
    }

    .siteHeader,
    .card {
      background: #20211e;
      border-color: #3a3b35;
    }
  }
</style>
