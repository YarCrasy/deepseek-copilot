---
import {
  anchorId,
  languageLabels,
  languages,
  navLabels,
  pageContent,
  pageSlugs,
  type Language,
  type PageSlug,
} from "../i18n";

const { title, description, lang = "en", currentSlug } = Astro.props as {
  title: string;
  description: string;
  lang?: Language;
  currentSlug?: PageSlug;
};

const currentPath = Astro.url.pathname;
const isRootDocument = currentPath === "/";
const isLegacyRootDocument = !isRootDocument && !currentPath.startsWith(`/${lang}/`);

function docsHref(targetLang: Language, targetSlug?: PageSlug): string {
  if (isRootDocument) {
    return targetSlug ? `${targetLang}/${targetSlug}/` : `${targetLang}/`;
  }

  if (currentSlug) {
    if (targetLang === lang) {
      if (!targetSlug) {
        return "../";
      }

      return targetSlug === currentSlug ? "./" : `../${targetSlug}/`;
    }

    const prefix = isLegacyRootDocument ? "../" : "../../";
    return targetSlug ? `${prefix}${targetLang}/${targetSlug}/` : `${prefix}${targetLang}/`;
  }

  if (targetLang === lang) {
    return targetSlug ? `${targetSlug}/` : "./";
  }

  return targetSlug ? `../${targetLang}/${targetSlug}/` : `../${targetLang}/`;
}

function assetHref(filename: string): string {
  if (isRootDocument) {
    return filename;
  }

  if (currentSlug) {
    return isLegacyRootDocument ? `../${filename}` : `../../${filename}`;
  }

  return `../${filename}`;
}

const tocItems = currentSlug
  ? pageContent[lang][currentSlug].sections.map((section) => ({
      href: `#${anchorId(section.title)}`,
      label: section.title,
    }))
  : pageSlugs.map((slug) => ({
      href: docsHref(lang, slug),
      label: navLabels[lang][slug],
    }));

const quickStartSlugs: PageSlug[] = ["intro", "user-manual"];
const projectSlugs: PageSlug[] = ["changelog", "technical-decisions", "references"];
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | DeepSeek Copilot</title>
    <meta name="description" content={description} />
    <link rel="icon" href={assetHref("favicon.svg")} />
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href={docsHref(lang)} aria-label="DeepSeek Copilot home">
        <img src={assetHref("favicon.svg")} alt="" width="28" height="28" />
        <span>DeepSeek Copilot</span>
      </a>
      <div class="topbarActions">
        <div class="languageSwitcher" aria-label="Language selector">
          {languages.map((item) => (
            <a class:list={[item === lang && "active"]} href={docsHref(item, currentSlug)} hreflang={item}>
              {languageLabels[item]}
            </a>
          ))}
        </div>
        <a class="platformLink" href="https://platform.deepseek.com/" target="_blank" rel="noreferrer">
          DeepSeek Platform
          <span aria-hidden="true">↗</span>
        </a>
      </div>
    </header>

    <div class="docsShell">
      <aside class="sidebar" aria-label="Documentation sections">
        <nav>
          <div class="navGroup">
            <p>Quick Start</p>
            <a class:list={["navRoot", !currentSlug && "active"]} href={docsHref(lang)}>Overview</a>
            {quickStartSlugs.map((slug) => (
              <a class:list={[currentSlug === slug && "active"]} href={docsHref(lang, slug)}>
                {navLabels[lang][slug]}
              </a>
            ))}
          </div>
          <div class="navGroup">
            <p>Project</p>
            {projectSlugs.map((slug) => (
              <a class:list={[currentSlug === slug && "active"]} href={docsHref(lang, slug)}>
                {navLabels[lang][slug]}
              </a>
            ))}
          </div>
        </nav>
      </aside>

      <main class="content">
        <slot />
      </main>

      <aside class="toc" aria-label="On this page">
        <div class="tocPanel">
          {tocItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </div>
      </aside>
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #1b1b1f;
    color: #ececf1;
    --bg: #1b1b1f;
    --panel: #202124;
    --panel-strong: #28282c;
    --border: #3a3a40;
    --border-soft: #303036;
    --text: #ececf1;
    --muted: #b8bac3;
    --dim: #8c8f99;
    --accent: #4aa8ff;
    --accent-soft: rgba(74, 168, 255, 0.12);
    --code: #2f3034;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:hover {
    color: var(--accent);
  }

  .topbar {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    min-height: 64px;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 0 20px;
    border-bottom: 1px solid var(--border-soft);
    background: rgba(32, 33, 36, 0.96);
    backdrop-filter: blur(10px);
  }

  .brand,
  .topbarActions,
  .languageSwitcher {
    display: flex;
    align-items: center;
  }

  .brand {
    gap: 10px;
    font-size: 1rem;
    font-weight: 700;
  }

  .brand img {
    display: block;
  }

  .topbarActions {
    gap: 16px;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .languageSwitcher {
    gap: 4px;
  }

  .languageSwitcher a {
    border-radius: 5px;
    padding: 6px 8px;
  }

  .languageSwitcher a.active {
    background: var(--panel-strong);
    color: var(--text);
  }

  .platformLink {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    white-space: nowrap;
  }

  .docsShell {
    display: grid;
    grid-template-columns: 300px minmax(0, 1fr) 260px;
    min-height: calc(100vh - 64px);
  }

  .sidebar,
  .toc {
    position: sticky;
    top: 64px;
    height: calc(100vh - 64px);
    overflow: auto;
  }

  .sidebar {
    border-right: 1px solid var(--border);
    background: #1f2024;
    padding: 16px 10px;
  }

  .navGroup {
    display: grid;
    gap: 4px;
  }

  .navGroup + .navGroup {
    margin-top: 18px;
  }

  .navGroup p {
    margin: 0 0 4px;
    padding: 0 10px;
    color: var(--accent);
    font-weight: 650;
  }

  .navGroup a {
    border-radius: 4px;
    color: #d7d8df;
    padding: 8px 12px;
    line-height: 1.35;
  }

  .navGroup a.navRoot {
    color: var(--accent);
    font-weight: 600;
  }

  .navGroup a.active {
    background: var(--panel-strong);
    color: var(--accent);
  }

  .content {
    width: min(100%, 1020px);
    padding: 28px clamp(28px, 5vw, 72px) 88px;
  }

  .toc {
    border-left: 1px solid var(--border-soft);
    padding: 28px 20px;
  }

  .tocPanel {
    display: grid;
    gap: 12px;
    border-left: 1px solid #5a5b63;
    padding-left: 16px;
    font-size: 0.9rem;
  }

  .tocPanel a {
    color: #d9dae1;
  }

  h1 {
    max-width: 820px;
    margin: 26px 0 20px;
    font-size: clamp(2.4rem, 6vw, 3.7rem);
    font-weight: 750;
    letter-spacing: 0;
    line-height: 1.05;
  }

  h2 {
    margin: 44px 0 14px;
    scroll-margin-top: 90px;
    font-size: 1.55rem;
    letter-spacing: 0;
  }

  p,
  li {
    line-height: 1.7;
  }

  .lead {
    max-width: 820px;
    color: #f0f0f3;
    font-size: 1.08rem;
  }

  .sectionList {
    display: grid;
    gap: 0;
    width: min(720px, 100%);
    margin-top: 30px;
    border: 1px solid var(--border);
  }

  .sectionList a {
    display: grid;
    gap: 3px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    background: var(--panel);
  }

  .sectionList a:last-child {
    border-bottom: 0;
  }

  .sectionList strong {
    color: var(--accent);
  }

  .sectionList span {
    color: var(--muted);
  }

  section {
    max-width: 860px;
  }

  ul {
    padding-left: 20px;
  }

  li + li {
    margin-top: 8px;
  }

  code {
    border-radius: 4px;
    background: var(--code);
    padding: 0.12em 0.32em;
    color: #f4f4f6;
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.92em;
  }

  .metadataTable {
    width: min(720px, 100%);
    margin: 28px 0;
    border-collapse: collapse;
    border: 1px solid #595a62;
  }

  .metadataTable th,
  .metadataTable td {
    padding: 14px 16px;
    border: 1px solid #595a62;
    text-align: left;
    vertical-align: top;
  }

  .metadataTable th {
    background: var(--panel-strong);
  }

  .metadataTable td {
    background: rgba(255, 255, 255, 0.02);
  }

  @media (max-width: 1100px) {
    .docsShell {
      grid-template-columns: 260px minmax(0, 1fr);
    }

    .toc {
      display: none;
    }
  }

  @media (max-width: 760px) {
    .topbar {
      position: static;
      align-items: flex-start;
      flex-direction: column;
      padding: 14px 16px;
    }

    .topbarActions {
      width: 100%;
      justify-content: space-between;
    }

    .docsShell {
      display: block;
    }

    .sidebar {
      position: static;
      height: auto;
      border-right: 0;
      border-bottom: 1px solid var(--border);
    }

    .navGroup {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .content {
      padding: 26px 18px 72px;
    }

    h1 {
      font-size: 2.35rem;
    }
  }

  @media (max-width: 520px) {
    .topbarActions,
    .languageSwitcher {
      align-items: flex-start;
      flex-direction: column;
    }

    .navGroup {
      grid-template-columns: 1fr;
    }
  }
</style>
